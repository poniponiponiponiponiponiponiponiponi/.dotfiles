[battery]
command=~/.config/i3blocks/battery
interval=5
LABEL=BAT 

[cpu_usage]
command=~/.config/i3blocks/cpu_usage
interval=3
LABEL=CPU 

[temperature]
command=~/.config/i3blocks/temperature
label=TEMP 
interval=3
SENSOR_CHIP="coretemp-isa-0000"

[memory]
command=~/.config/i3blocks/memory
color=#bc6ec5
interval=1
LABEL=RAM 

[time]
command=date '+%F %T '
interval=1

[idk]
command=echo idk
interval=1